class Solution {
    int [] x = {-1,1,0,0};
    int [] y = {0,0,-1,1};
    public void dfs(int [][] matrix, int [][]dp , int r ,int c,int R , int C ){
        for(int i=0;i<4;i++){
            int nx = x[i]+r;
            int ny = y[i]+c;
            if(nx>=0 && nx<R && ny>=0 && ny<C && matrix[r][c] <matrix[nx][ny]){
                if(dp[nx][ny]==0)
                dfs(matrix , dp , nx,ny,R,C);
                dp[r][c] =Math.max(dp[r][c],dp[nx][ny]); 

            }
        }
        dp[r][c]++;
        // return;
        
    }
    public int longestIncreasingPath(int[][] matrix) {
        int R = matrix.length;
        int C = matrix[0].length;
        int [][] dp = new int [R][C];
        for(int r=0;r<R;r++){
            for(int c=0;c<C;c++){
                if(dp[r][c]==0){
                    dfs(matrix , dp, r ,c,R,C);
                }
            }
        }
        int max = Integer.MIN_VALUE;
        for(int i=0;i<R;i++){
            for(int j=0;j<C;j++){
                max = Math.max(max , dp[i][j]);
            }
        }
        return max;
    }
}
